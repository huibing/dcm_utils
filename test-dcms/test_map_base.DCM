* encoding="UTF-8"
* DAMOS format
* Test file for 2D map diff testing

KONSERVIERUNG_FORMAT 2.0

* Base 2D map for testing
GRUPPENKENNFELD MAP_TEST_001 6 4
   LANGNAME "Base 2D calibration map"
   EINHEIT_X "deg/s"
   EINHEIT_Y "km/h"
   EINHEIT_W "mA"
*SSTX	AXIS_X_001
*SSTY	AXIS_Y_001
   ST/X   -10.0000000000000000   -5.0000000000000000   0.0000000000000000   5.0000000000000000   10.0000000000000000   15.0000000000000000
   ST/Y   0.0000000000000000
   WERT   100.0000000000000000   110.0000000000000000   120.0000000000000000   130.0000000000000000   140.0000000000000000   150.0000000000000000
   ST/Y   20.0000000000000000
   WERT   200.0000000000000000   220.0000000000000000   240.0000000000000000   260.0000000000000000   280.0000000000000000   300.0000000000000000
   ST/Y   40.0000000000000000
   WERT   300.0000000000000000   330.0000000000000000   360.0000000000000000   390.0000000000000000   420.0000000000000000   450.0000000000000000
   ST/Y   60.0000000000000000
   WERT   400.0000000000000000   440.0000000000000000   480.0000000000000000   520.0000000000000000   560.0000000000000000   600.0000000000000000
END

* Axis distributions
STUETZSTELLENVERTEILUNG AXIS_X_001 6
*SST
   LANGNAME "X axis distribution"
   EINHEIT_X "deg/s"
   ST/X   -10.0000000000000000   -5.0000000000000000   0.0000000000000000   5.0000000000000000   10.0000000000000000   15.0000000000000000
END

STUETZSTELLENVERTEILUNG AXIS_Y_001 4
*SST
   LANGNAME "Y axis distribution"
   EINHEIT_X "km/h"
   ST/X   0.0000000000000000   20.0000000000000000   40.0000000000000000   60.0000000000000000
END
